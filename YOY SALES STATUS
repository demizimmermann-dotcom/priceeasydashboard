*{margin:0;padding:0;box-sizing:border-box}body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text)}
.hdr{padding:24px 36px 18px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--border)}
.hdr h1{font-size:21px;font-weight:700}.hdr h1 b{color:var(--c26)}.hdr-sub{font-size:12px;color:var(--muted);margin-top:2px}
