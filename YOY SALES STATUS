.legend-d{width:12px;height:4px;border-radius:2px}.dash{padding:20px 36px}
.kpis{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:20px}
.kpi{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:20px}
.kpi-l{font-size:10px;text-transform:uppercase;letter-spacing:1.2px;color:var(--muted);font-weight:600;margin-bottom:14px}
.kpi-row{display:grid;grid-template-columns:1fr auto 1fr;gap:10px;align-items:center}.kpi-m{text-align:center}
.kpi-ml{font-size:10px;color:var(--muted);margin-bottom:2px}.kpi-v{font-family:'JetBrains Mono',monospace;font-size:20px;font-weight:700}
.kpi-v.y25{color:var(--c25)}.kpi-v.y26{color:var(--c26)}
.kpi-div{width:1px;height:44px;background:var(--border);position:relative}
.badge{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-size:10px;font-weight:700;padding:2px 7px;border-radius:16px;white-space:nowrap;font-family:'JetBrains Mono',monospace}
.badge.up{background:rgba(34,197,94,.15);color:var(--green)}.badge.dn{background:rgba(239,68,68,.15);color:var(--red)}.badge.nu{background:rgba(113,113,122,.15);color:var(--muted)}
.kpi-f{margin-top:10px;padding-top:10px;border-top:1px solid var(--border);display:flex;justify-content:space-between;font-size:10px}
.kpi-f span:first-child{color:var(--muted)}.kpi-f span:last-child{font-family:'JetBrains Mono',monospace;font-weight:600;color:var(--purple)}
.row{display:grid;gap:14px;margin-bottom:20px}.r2{grid-template-columns:1.4fr 1fr}.r22{grid-template-columns:1fr 1fr}.full{grid-column:1/-1}
.card{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:20px}
.card-t{font-size:13px;font-weight:600;margin-bottom:14px;display:flex;align-items:center;gap:7px}
.dot{width:7px;height:7px;border-radius:50%}
.comp-r{display:flex;align-items:center;gap:10px;margin-bottom:12px}.comp-l{width:120px;font-size:11px;text-align:right;flex-shrink:0}
.comp-b{flex:1;display:flex;flex-direction:column;gap:2px}.comp-bw{display:flex;align-items:center;gap:6px}
.comp-bar{height:16px;border-radius:3px;min-width:2px;transition:width .6s}.comp-bar.y25{background:var(--c25)}.comp-bar.y26{background:var(--c26)}
.comp-bv{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--muted)}.comp-mt{font-size:8px;color:var(--muted);width:24px;flex-shrink:0}
.tbl{max-height:360px;overflow-y:auto}.tbl table{width:100%;border-collapse:collapse}
.tbl th{text-align:left;font-size:10px;text-transform:uppercase;letter-spacing:.8px;color:var(--muted);padding:7px 10px;border-bottom:1px solid var(--border);font-weight:600;position:sticky;top:0;background:var(--card)}
.tbl td{padding:8px 10px;font-size:12px;border-bottom:1px solid #1f2130}.tbl tr:hover td{background:rgba(59,130,246,.04)}
.mono{font-family:'JetBrains Mono',monospace;font-size:11px}
.yr{font-size:10px;padding:2px 6px;border-radius:4px;font-weight:600}.yr.a{background:rgba(245,158,11,.15);color:var(--c25)}.yr.b{background:rgba(59,130,246,.15);color:var(--c26)}
.st{padding:2px 8px;border-radius:16px;font-size:10px;font-weight:600}.st.ap{background:rgba(34,197,94,.15);color:var(--green)}.st.ds{background:rgba(245,158,11,.15);color:var(--c25)}.st.dr{background:rgba(59,130,246,.15);color:var(--c26)}
.tbl::-webkit-scrollbar{width:5px}.tbl::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}
@media(max-width:1100px){.kpis{grid-template-columns:repeat(2,1fr)}.r2,.r22{grid-template-columns:1fr}.dash{padding:14px}}
</style>
</head>
