new Chart(document.getElementById('cumulC'),{type:'line',data:{labels:mos,datasets:[{label:'2025',data:cu5,borderColor:'rgba(245,158,11,.9)',backgroundColor:'rgba(245,158,11,.08)',fill:true,tension:.3,pointRadius:3,borderWidth:2},{label:'2026',data:cu6,borderColor:'rgba(59,130,246,.9)',backgroundColor:'rgba(59,130,246,.08)',fill:true,tension:.3,pointRadius:4,borderWidth:2.5}]},options:{...co,scales:{...co.scales,y:{...co.scales.y,ticks:{...co.scales.y.ticks,callback:v=>f(v)}}}}});
// Count
new Chart(document.getElementById('countC'),{type:'bar',data:{labels:mos,datasets:[{label:'2025',data:mos.map((_,i)=>y25.filter(d=>d.month===i+1).length),backgroundColor:'rgba(245,158,11,.7)',borderRadius:4,barPercentage:.4},{label:'2026',data:mos.map((_,i)=>i<4?y26.filter(d=>d.month===i+1).length:null),backgroundColor:'rgba(59,130,246,.7)',borderRadius:4,barPercentage:.4}]},options:co});
// Status
const sts=['Approved','DocuSign Sent','Draft'];
new Chart(document.getElementById('statusC'),{type:'bar',data:{labels:sts,datasets:[{label:'2025 YTD',data:sts.map(s=>y25y.filter(d=>d.status===s).length),backgroundColor:'rgba(245,158,11,.7)',borderRadius:5,barPercentage:.4},{label:'2026 YTD',data:sts.map(s=>y26y.filter(d=>d.status===s).length),backgroundColor:'rgba(59,130,246,.7)',borderRadius:5,barPercentage:.4}]},options:co});
// Scope
const scs=[...new Set(D.map(d=>d.scope))];
new Chart(document.getElementById('scopeC'),{type:'bar',data:{labels:scs,datasets:[{label:'2025 YTD',data:scs.map(s=>y25y.filter(d=>d.scope===s).length),backgroundColor:'rgba(245,158,11,.7)',borderRadius:5,barPercentage:.4},{label:'2026 YTD',data:scs.map(s=>y26y.filter(d=>d.scope===s).length),backgroundColor:'rgba(59,130,246,.7)',borderRadius:5,barPercentage:.4}]},options:co});
// Products
const pr={};[...y25y,...y26y].forEach(d=>{if(d.products)d.products.split(', ').forEach(x=>{if(!pr[x])pr[x]={a:0,b:0};if(d.year===2025)pr[x].a+=d.arr;else pr[x].b+=d.arr})});
const sp=Object.entries(pr).sort((a,b)=>(b[1].a+b[1].b)-(a[1].a+a[1].b)).slice(0,8),mx=Math.max(...sp.flatMap(([_,v])=>[v.a,v.b]));
document.getElementById('prodC').innerHTML=sp.map(([n,v])=>`<div class="comp-r"><div class="comp-l">${n.length>24?n.slice(0,22)+'...':n}</div><div class="comp-b"><div class="comp-bw"><div class="comp-mt">2025</div><div class="comp-bar y25" style="width:${Math.max(v.a/mx*100,.5)}%"></div><div class="comp-bv">${f(v.a)}</div></div><div class="comp-bw"><div class="comp-mt">2026</div><div class="comp-bar y26" style="width:${Math.max(v.b/mx*100,.5)}%"></div><div class="comp-bv">${f(v.b)}</div></div></div></div>`).join('');
// Monthly ARR
new Chart(document.getElementById('marrC'),{type:'bar',data:{labels:mos,datasets:[{label:'2025',data:mos.map((_,i)=>y25.filter(d=>d.month===i+1).reduce((s,d)=>s+d.arr,0)),backgroundColor:'rgba(245,158,11,.7)',borderRadius:4,barPercentage:.4},{label:'2026',data:mos.map((_,i)=>i<4?y26.filter(d=>d.month===i+1).reduce((s,d)=>s+d.arr,0):null),backgroundColor:'rgba(59,130,246,.7)',borderRadius:4,barPercentage:.4}]},options:{...co,scales:{...co.scales,y:{...co.scales.y,ticks:{...co.scales.y.ticks,callback:v=>f(v)}}}}});
// Table
const topDeals=D.filter(d=>d.arr>0).sort((a,b)=>b.arr-a.arr).slice(0,20);
document.getElementById('tb').innerHTML=topDeals.map(d=>`<tr><td>${d.client}</td><td class="mono">${f(d.arr)}</td><td><span class="st ${d.status==='Approved'?'ap':d.status==='DocuSign Sent'?'ds':'dr'}">${d.status}</span></td><td><span class="yr ${d.year===2025?'a':'b'}">${d.year}</span></td><td style="color:var(--muted)">${d.mn}</td></tr>`).join('');
</script>
</body>
</html>
